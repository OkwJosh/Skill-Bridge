      "item": [
        {
          "name": "Health Check (No Auth)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/health/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "health",
                ""
              ]
            }
          }
        }
      ]
    }
  ],
